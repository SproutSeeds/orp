{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openresearchprotocol.com/spec/v1/kernel-proposal.schema.json",
  "title": "ORP Reasoning Kernel Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_kind",
    "title",
    "status",
    "summary",
    "target_scope",
    "proposed_change",
    "rationale",
    "evidence_refs",
    "compatibility_notes",
    "migration_plan",
    "evaluation_plan"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "proposal_kind": {
      "type": "string",
      "enum": [
        "add_field",
        "new_class",
        "requirement_change",
        "deprecate_field"
      ]
    },
    "title": {
      "$ref": "#/$defs/non_empty_text"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "accepted",
        "rejected"
      ]
    },
    "summary": {
      "$ref": "#/$defs/non_empty_text"
    },
    "target_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_classes",
        "fields"
      ],
      "properties": {
        "artifact_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "task",
              "decision",
              "hypothesis",
              "experiment",
              "checkpoint",
              "policy",
              "result"
            ]
          },
          "uniqueItems": true
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_text"
          },
          "uniqueItems": true
        }
      }
    },
    "proposed_change": {
      "$ref": "#/$defs/text_list"
    },
    "rationale": {
      "$ref": "#/$defs/text_list"
    },
    "evidence_refs": {
      "$ref": "#/$defs/text_list"
    },
    "compatibility_notes": {
      "$ref": "#/$defs/text_list"
    },
    "migration_plan": {
      "$ref": "#/$defs/text_list"
    },
    "evaluation_plan": {
      "$ref": "#/$defs/text_list"
    }
  },
  "$defs": {
    "non_empty_text": {
      "type": "string",
      "minLength": 1
    },
    "text_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_text"
      }
    }
  }
}
