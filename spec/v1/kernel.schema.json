{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openresearchprotocol.com/spec/v1/kernel.schema.json",
  "title": "ORP Reasoning Kernel Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_class"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "task",
        "decision",
        "hypothesis",
        "experiment",
        "checkpoint",
        "policy",
        "result"
      ]
    },
    "object": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "goal": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "boundary": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "constraints": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "invariants": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "failure_modes": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "evidence_expectations": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "success_criteria": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "next_action": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "canonical_target": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "artifact_refs": {
      "$ref": "#/$defs/text_list"
    },
    "question": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "chosen_path": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "rejected_alternatives": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "rationale": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "consequences": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "claim": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "assumptions": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "test_path": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "falsifiers": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "objective": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "method": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "inputs": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "outputs": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "interpretation_limits": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "completed_unit": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "current_state": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "risks": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "next_handoff_target": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "scope": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "rule": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "enforcement_surface": {
      "$ref": "#/$defs/text_or_text_list"
    },
    "evidence_paths": {
      "$ref": "#/$defs/text_list"
    },
    "status": {
      "$ref": "#/$defs/non_empty_text"
    },
    "next_follow_up": {
      "$ref": "#/$defs/text_or_text_list"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "artifact_class": {
            "const": "task"
          }
        }
      },
      "then": {
        "required": [
          "object",
          "goal",
          "boundary",
          "constraints",
          "success_criteria"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact_class": {
            "const": "decision"
          }
        }
      },
      "then": {
        "required": [
          "question",
          "chosen_path",
          "rejected_alternatives",
          "rationale",
          "consequences"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact_class": {
            "const": "hypothesis"
          }
        }
      },
      "then": {
        "required": [
          "claim",
          "boundary",
          "assumptions",
          "test_path",
          "falsifiers"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact_class": {
            "const": "experiment"
          }
        }
      },
      "then": {
        "required": [
          "objective",
          "method",
          "inputs",
          "outputs",
          "evidence_expectations",
          "interpretation_limits"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact_class": {
            "const": "checkpoint"
          }
        }
      },
      "then": {
        "required": [
          "completed_unit",
          "current_state",
          "risks",
          "next_handoff_target",
          "artifact_refs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact_class": {
            "const": "policy"
          }
        }
      },
      "then": {
        "required": [
          "scope",
          "rule",
          "rationale",
          "invariants",
          "enforcement_surface"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact_class": {
            "const": "result"
          }
        }
      },
      "then": {
        "required": [
          "claim",
          "evidence_paths",
          "status",
          "interpretation_limits",
          "next_follow_up"
        ]
      }
    }
  ],
  "$defs": {
    "non_empty_text": {
      "type": "string",
      "minLength": 1
    },
    "text_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_text"
      }
    },
    "text_or_text_list": {
      "oneOf": [
        {
          "$ref": "#/$defs/non_empty_text"
        },
        {
          "$ref": "#/$defs/text_list"
        }
      ]
    }
  }
}
