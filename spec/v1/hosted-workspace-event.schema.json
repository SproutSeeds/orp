{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openresearchprotocol.com/spec/v1/hosted-workspace-event.schema.json",
  "title": "ORP Hosted Workspace Event",
  "description": "Timeline event for one hosted ORP workspace, used to build the detail-page activity stream and state history.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "workspace_id",
    "event_type",
    "actor",
    "created_at_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "workspace.created",
        "workspace.updated",
        "workspace.opened",
        "snapshot.created",
        "tab.added",
        "tab.removed",
        "tab.updated",
        "focus.updated",
        "trajectory.updated",
        "summary.updated",
        "bridge.synced"
      ]
    },
    "snapshot_id": {
      "type": "string"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "system"
          ]
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "tab_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "state_excerpt": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tab_count": {
          "type": "integer",
          "minimum": 0
        },
        "current_focus": {
          "type": "string"
        },
        "trajectory": {
          "type": "string"
        }
      }
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
