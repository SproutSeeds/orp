{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openresearchprotocol.com/spec/v1/hosted-workspace.schema.json",
  "title": "ORP Hosted Workspace",
  "description": "Canonical hosted source-of-truth record for an ORP workspace that can be reopened locally and inspected on ORP.Earth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace_id",
    "title",
    "source_of_truth",
    "state",
    "created_at_utc",
    "updated_at_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "team",
        "public"
      ]
    },
    "source_of_truth": {
      "type": "string",
      "const": "hosted-workspace"
    },
    "linked_idea": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idea_id"
      ],
      "properties": {
        "idea_id": {
          "type": "string",
          "minLength": 1
        },
        "idea_title": {
          "type": "string"
        },
        "relationship": {
          "type": "string",
          "enum": [
            "primary",
            "mirror",
            "reference"
          ]
        }
      }
    },
    "bridge": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "legacy_idea_notes_enabled": {
          "type": "boolean"
        },
        "legacy_idea_id": {
          "type": "string"
        },
        "legacy_manifest_synced_at_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "state": {
      "$ref": "#/$defs/current_state"
    },
    "latest_event": {
      "$ref": "#/$defs/event_preview"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tab_count": {
          "type": "integer",
          "minimum": 0
        },
        "project_count": {
          "type": "integer",
          "minimum": 0
        },
        "codex_session_count": {
          "type": "integer",
          "minimum": 0
        },
        "tmux_session_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "last_opened_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "last_captured_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "current_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state_version",
        "snapshot_id",
        "updated_at_utc",
        "tab_count",
        "tabs"
      ],
      "properties": {
        "state_version": {
          "type": "integer",
          "minimum": 1
        },
        "snapshot_id": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "current_focus": {
          "type": "string"
        },
        "trajectory": {
          "type": "string"
        },
        "opened_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "captured_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "tab_count": {
          "type": "integer",
          "minimum": 0
        },
        "capture_context": {
          "$ref": "#/$defs/capture_context"
        },
        "tabs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tab"
          }
        }
      }
    },
    "capture_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_app": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "snapshot",
            "watch",
            "sync",
            "manual"
          ]
        },
        "host": {
          "type": "string"
        },
        "window_id": {
          "type": "integer",
          "minimum": 1
        },
        "window_index": {
          "type": "integer",
          "minimum": 1
        },
        "poll_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "terminal_frontend": {
          "type": "string",
          "enum": [
            "iterm",
            "terminal",
            "unknown"
          ]
        },
        "durable_backend": {
          "type": "string",
          "enum": [
            "tmux",
            "direct",
            "unknown"
          ]
        }
      }
    },
    "tab": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tab_id",
        "order_index",
        "project_root",
        "status"
      ],
      "properties": {
        "tab_id": {
          "type": "string",
          "minLength": 1
        },
        "order_index": {
          "type": "integer",
          "minimum": 0
        },
        "title": {
          "type": "string"
        },
        "project_root": {
          "type": "string",
          "pattern": "^/"
        },
        "repo_label": {
          "type": "string"
        },
        "codex_session_id": {
          "type": "string"
        },
        "tmux_session_name": {
          "type": "string"
        },
        "terminal_title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "removed",
            "archived"
          ]
        },
        "current_task": {
          "type": "string"
        },
        "focus_summary": {
          "type": "string"
        },
        "trajectory_summary": {
          "type": "string"
        },
        "last_activity_at_utc": {
          "type": "string",
          "format": "date-time"
        },
        "linked_idea_id": {
          "type": "string"
        },
        "linked_feature_id": {
          "type": "string"
        }
      }
    },
    "event_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "created_at_utc"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "created_at_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
