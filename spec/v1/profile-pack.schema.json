{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orp.dev/spec/v1/profile-pack.schema.json",
  "title": "ORP Profile Pack Metadata v1",
  "description": "Metadata contract for downloadable ORP profile packs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "pack_id",
    "name",
    "version",
    "description",
    "templates"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "orp_version_min": {
      "type": "string"
    },
    "install": {
      "$ref": "#/$defs/install"
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/variable"
      }
    },
    "templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/template"
      }
    }
  },
  "$defs": {
    "variable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "default": {
          "type": "string"
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "description"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "output_hint": {
          "type": "string"
        },
        "default_profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_includes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "report_name": {
          "type": "string"
        },
        "components": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/installComponent"
          }
        }
      }
    },
    "installComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_id"
      ],
      "properties": {
        "template_id": {
          "type": "string"
        },
        "output_name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "required_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
