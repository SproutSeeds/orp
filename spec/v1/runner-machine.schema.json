{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openresearchprotocol.com/spec/v1/runner-machine.schema.json",
  "title": "ORP Runner Machine",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "machine_id",
    "machine_name",
    "platform",
    "runner_enabled"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "machine_id": {
      "type": "string",
      "minLength": 1
    },
    "machine_name": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string"
    },
    "app_version": {
      "type": "string"
    },
    "runner_enabled": {
      "type": "boolean"
    },
    "linked_email": {
      "type": "string"
    },
    "last_heartbeat_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "last_sync_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
