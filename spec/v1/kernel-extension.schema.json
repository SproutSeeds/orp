{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openresearchprotocol.com/spec/v1/kernel-extension.schema.json",
  "title": "ORP Reasoning Kernel Extension",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "extension_id",
    "title",
    "status",
    "description",
    "fields"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "extension_id": {
      "$ref": "#/$defs/non_empty_text"
    },
    "title": {
      "$ref": "#/$defs/non_empty_text"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "experimental",
        "active",
        "retired"
      ]
    },
    "description": {
      "$ref": "#/$defs/non_empty_text"
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "artifact_classes",
          "rationale"
        ],
        "properties": {
          "name": {
            "$ref": "#/$defs/non_empty_text"
          },
          "kind": {
            "type": "string",
            "enum": [
              "non_empty_text",
              "text_list",
              "text_or_text_list"
            ]
          },
          "artifact_classes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "task",
                "decision",
                "hypothesis",
                "experiment",
                "checkpoint",
                "policy",
                "result"
              ]
            },
            "uniqueItems": true
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "rationale": {
            "$ref": "#/$defs/non_empty_text"
          }
        }
      }
    }
  },
  "$defs": {
    "non_empty_text": {
      "type": "string",
      "minLength": 1
    }
  }
}
